APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Hostinger shared hosting only provides MySQL/MariaDB (no PostgreSQL).
# Use sqlite locally if you don't want to run a local MySQL server.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

# database driver is used for session/cache/queue everywhere (no Redis on shared hosting)
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

# Transactional email provider (Resend/Postmark/Mailgun/etc.) — fill in once chosen.
# Hostinger shared SMTP is not reliable enough for verification/reset/notification emails.
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# Mono (bank integration) — see https://app.withmono.com for keys
MONO_SECRET_KEY=
MONO_PUBLIC_KEY=
MONO_WEBHOOK_SECRET=
MONO_BASE_URL=https://api.withmono.com

# OpenAI (AI insights) — calls only ever happen inside the scheduled batch
# job (app:generate-insights), never synchronously on a request.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
